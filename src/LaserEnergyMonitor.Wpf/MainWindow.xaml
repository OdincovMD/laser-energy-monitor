<Window x:Class="LaserEnergyMonitor.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laser Energy Monitor"
        Icon="Assets/AppIcon.png"
        Width="1160"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource PageBrush}" Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Run Setup" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="BeamGage SDK and StarLab log file" Style="{StaticResource SectionCaption}" />

                    <TextBlock Text="SOURCES" Style="{StaticResource FieldGroupTitle}" />
                    <Border Style="{StaticResource FieldGroupRule}" Margin="0,0,0,10" />

                    <TextBlock Text="BeamGage source" Style="{StaticResource FieldLabel}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="BeamPhysicalSourceComboBox"
                                  SelectionChanged="OnBeamGagePhysicalSourceSelectionChanged" />
                        <Button x:Name="RefreshBeamGageSourcesButton"
                                Grid.Column="2"
                                Content="Scan"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnRefreshBeamGageSourcesClicked" />
                        <Button x:Name="ReconnectBeamGageButton"
                                Grid.Column="4"
                                Content="Connect"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnReconnectBeamGageClicked" />
                    </Grid>

                    <TextBlock Text="StarLab log file" Style="{StaticResource FieldLabel}" Margin="0,12,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StarLabLogPathTextBox" />
                        <Button x:Name="BrowseStarLabLogButton"
                                Grid.Column="2"
                                Content="Browse"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnBrowseStarLabLogClicked" />
                    </Grid>

                    <TextBlock Text="PARAMETERS" Style="{StaticResource FieldGroupTitle}" />
                    <Border Style="{StaticResource FieldGroupRule}" Margin="0,0,0,10" />

                    <TextBlock Text="Session" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="SessionNameTextBox" Text="Prototype Session" />

                    <TextBlock Text="Window" Style="{StaticResource FieldLabel}" Margin="0,10,0,4" />
                    <TextBox x:Name="WindowSizeTextBox" Text="20" />

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Enter %" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="EnterThresholdTextBox" Text="0.5" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Exit %" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="ExitThresholdTextBox" Text="1.0" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="OUTPUT" Style="{StaticResource FieldGroupTitle}" />
                    <Border Style="{StaticResource FieldGroupRule}" Margin="0,0,0,10" />

                    <TextBlock Text="Export" Style="{StaticResource FieldLabel}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputPathTextBox" />
                        <Button x:Name="BrowseButton"
                                Grid.Column="2"
                                Content="Browse"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnBrowseClicked" />
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StartButton"
                                Content="Start"
                                Style="{StaticResource PrimaryButton}"
                                Click="OnStartClicked" />
                        <Button x:Name="StopButton"
                                Grid.Column="2"
                                Content="Stop"
                                Style="{StaticResource SecondaryButton}"
                                Click="OnStopClicked" />
                    </Grid>

                    <TextBlock Text="STATUS" Style="{StaticResource FieldGroupTitle}" />
                    <Border Style="{StaticResource FieldGroupRule}" Margin="0,0,0,10" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Beam" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="BeamStatusText" Grid.Column="1" Text="Not connected" TextWrapping="Wrap" TextTrimming="None" />
                        <TextBlock Grid.Row="1" Text="Ophir" Style="{StaticResource FieldLabel}" Margin="0,8,0,0" />
                        <TextBlock x:Name="OphirStatusText" Grid.Row="1" Grid.Column="1" Text="Log file not selected" TextWrapping="Wrap" TextTrimming="None" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="2" Text="Last" Style="{StaticResource FieldLabel}" Margin="0,8,0,0" />
                        <TextBlock x:Name="LastStatusText" Grid.Row="2" Grid.Column="1" Text="Application ready." TextWrapping="Wrap" TextTrimming="None" Margin="0,8,0,0" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="160" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Live Measurements" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Current BeamGage and StarLab values" Style="{StaticResource SectionCaption}" />
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Columns="2" Rows="5">
                        <Border Style="{StaticResource MetricTile}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Beam Energy" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="BeamEnergyText" Text="-" Style="{StaticResource LiveMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricTile}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Ophir Energy" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="OphirEnergyText" Text="-" Style="{StaticResource LiveMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricTile}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Beam Avg" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="BeamAverageText" Text="-" Style="{StaticResource LiveMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricTile}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Ophir Avg" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="OphirAverageText" Text="-" Style="{StaticResource LiveMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="BeamStabilityTile" Style="{StaticResource MetricTile}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Beam Stability" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="BeamStabilityText" Text="-" Style="{StaticResource CompactMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="OphirStabilityTile" Style="{StaticResource MetricTile}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Ophir Stability" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="OphirStabilityText" Text="-" Style="{StaticResource CompactMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="OverallStabilityTile" Style="{StaticResource MetricTile}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Overall Stability" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="StabilityText" Text="-" Style="{StaticResource CompactMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricTile}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Record" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="RecordIdText" Text="-" Style="{StaticResource LiveMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricTile}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Last Update" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="LastUpdateText" Text="-" Style="{StaticResource LiveMetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricTile}">
                            <StackPanel>
                                <TextBlock Text="Stationary Entries" Style="{StaticResource FieldLabel}" />
                                <TextBlock x:Name="StationaryEntriesText" Text="0" Style="{StaticResource LiveMetricValue}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Session Review" Style="{StaticResource SectionTitle}" />
                    <UniformGrid Grid.Row="2" Columns="4">
                        <StackPanel>
                            <TextBlock Text="Samples" Style="{StaticResource FieldLabel}" />
                            <TextBlock x:Name="SummarySamplesText" Text="0" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Events" Style="{StaticResource FieldLabel}" />
                            <TextBlock x:Name="SummaryEventsCountText" Text="0" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Segments" Style="{StaticResource FieldLabel}" />
                            <TextBlock x:Name="SummarySegmentsText" Text="0" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Faults" Style="{StaticResource FieldLabel}" />
                            <TextBlock x:Name="SummaryFaultsText" Text="0" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
